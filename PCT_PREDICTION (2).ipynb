import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
from sklearn.metrics import confusion_matrix

def calculate_net_benefit(y_true, y_pred_proba, threshold):
    """
    Calculate net benefit at a given threshold.

    Parameters:
    -----------
    y_true : array
        True binary labels (0=negative, 1=positive)
    y_pred_proba : array
        Predicted probabilities for positive class
    threshold : float
        Probability threshold for classification (0-1)

    Returns:
    --------
    net_benefit : float
        Net benefit at this threshold
    """
    y_pred = (y_pred_proba >= threshold).astype(int)

    tn, fp, fn, tp = confusion_matrix(y_true, y_pred).ravel()
    n = len(y_true)

    # Net benefit formula
    net_benefit = (tp / n) - (fp / n) * (threshold / (1 - threshold))

    return net_benefit


def decision_curve_analysis(y_true, y_pred_proba, model_name="Model"):
    """
    Perform decision curve analysis across all thresholds.

    Returns:
    --------
    dca_df : DataFrame
        Columns: threshold, net_benefit_model, net_benefit_all, net_benefit_none
    """
    thresholds = np.arange(0.01, 1.00, 0.01)

    results = []

    for threshold in thresholds:
        # Model net benefit
        nb_model = calculate_net_benefit(y_true, y_pred_proba, threshold)

        # "Treat all" strategy (test everyone)
        # Assumes all patients are positive
        prevalence = y_true.mean()
        nb_all = prevalence - (1 - prevalence) * (threshold / (1 - threshold))

        # "Treat none" strategy (test no one)
        nb_none = 0

        results.append({
            'threshold': threshold,
            'net_benefit_model': nb_model,
            'net_benefit_all': nb_all,
            'net_benefit_none': nb_none
        })

    return pd.DataFrame(results)


def plot_decision_curve(dca_results, model_name="Model", save_path=None):
    """
    Plot decision curve analysis.
    """
    plt.figure(figsize=(10, 6))

    plt.plot(dca_results['threshold'], dca_results['net_benefit_model'],
             'b-', linewidth=2, label=model_name)
    plt.plot(dca_results['threshold'], dca_results['net_benefit_all'],
             'r--', linewidth=2, label='Test All Patients')
    plt.plot(dca_results['threshold'], dca_results['net_benefit_none'],
             'k--', linewidth=2, label='Test No Patients')

    plt.xlabel('Threshold Probability', fontsize=12)
    plt.ylabel('Net Benefit', fontsize=12)
    plt.title(f'Decision Curve Analysis - {model_name}', fontsize=14)
    plt.legend(loc='upper right', fontsize=10)
    plt.grid(True, alpha=0.3)
    plt.xlim([0, 1])

    # Find optimal threshold
    optimal_idx = dca_results['net_benefit_model'].idxmax()
    optimal_threshold = dca_results.loc[optimal_idx, 'threshold']
    optimal_nb = dca_results.loc[optimal_idx, 'net_benefit_model']

    plt.axvline(x=optimal_threshold, color='green', linestyle=':',
                label=f'Optimal threshold: {optimal_threshold:.2f}')

    if save_path:
        plt.savefig(save_path, dpi=300, bbox_inches='tight')

    plt.tight_layout()
    plt.show()

    return optimal_threshold, optimal_nb


def compare_models_dca(y_true, models_dict):
    """
    Compare multiple models using DCA.

    Parameters:
    -----------
    y_true : array
        True labels
    models_dict : dict
        {'Model Name': predicted_probabilities}
    """
    plt.figure(figsize=(12, 7))

    # Test all and test none strategies (same for all models)
    thresholds = np.arange(0.01, 1.00, 0.01)
    prevalence = y_true.mean()

    nb_all = [prevalence - (1 - prevalence) * (t / (1 - t)) for t in thresholds]
    nb_none = [0] * len(thresholds)

    plt.plot(thresholds, nb_all, 'k--', linewidth=1.5, label='Test All', alpha=0.7)
    plt.plot(thresholds, nb_none, 'gray', linewidth=1.5, label='Test None', alpha=0.7)

    # Plot each model
    colors = ['blue', 'orange', 'green', 'red', 'purple', 'brown']

    for idx, (model_name, y_pred_proba) in enumerate(models_dict.items()):
        dca_results = decision_curve_analysis(y_true, y_pred_proba, model_name)

        plt.plot(dca_results['threshold'], dca_results['net_benefit_model'],
                linewidth=2, label=model_name, color=colors[idx % len(colors)])

    plt.xlabel('Threshold Probability', fontsize=12)
    plt.ylabel('Net Benefit', fontsize=12)
    plt.title('Decision Curve Analysis - Model Comparison', fontsize=14)
    plt.legend(loc='upper right', fontsize=10)
    plt.grid(True, alpha=0.3)
    plt.xlim([0, 1])
    plt.tight_layout()
    plt.show()


