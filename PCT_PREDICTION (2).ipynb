# ✅ FIXED: use external_rows (defined in section 15)
if len(external_rows) > 0:
    for model_name in top_models:
        if model_name not in results:
            continue

        cal = results[model_name]["calibrated"]
        thr_bal = external_thresholds[model_name]["balanced"]

        proba_ext = cal.predict_proba(X_ext)[:, 1]
        y_pred_ext = (proba_ext >= thr_bal).astype(int)

        if target_cont in ext.columns:
            y_ext_true = (ext[target_cont] >= 0.5).astype(int)

            tn, fp, fn, tp = confusion_matrix(y_ext_true, y_pred_ext).ravel()
            n_ext = len(y_ext_true)

            accuracy    = accuracy_score(y_ext_true, y_pred_ext)
            sensitivity = tp / (tp + fn) if (tp + fn) > 0 else 0
            specificity = tn / (tn + fp) if (tn + fp) > 0 else 0
            ppv         = tp / (tp + fp) if (tp + fp) > 0 else 0
            npv         = tn / (tn + fn) if (tn + fn) > 0 else 0
            auc         = roc_auc_score(y_ext_true, proba_ext)

            # ✅ Cohen's kappa calculation
            p_o = accuracy
            p_yes = ((tp + fp)/n_ext) * ((tp + fn)/n_ext)
            p_no  = ((tn + fn)/n_ext) * ((tn + fp)/n_ext)
            p_e   = p_yes + p_no
            kappa = (p_o - p_e) / (1 - p_e) if (1 - p_e) != 0 else 0

            # Bootstrap CI for AUC
            auc_ci_ext = bootstrap_auc_ci(y_ext_true, proba_ext, n_boot=2000, seed=42)
            auc_with_ci = f"{auc:.2f} ({auc_ci_ext[0]:.2f}-{auc_ci_ext[2]:.2f})"

            table3_rows.append({
                'Model':       model_name,
                'Accuracy':    f"{accuracy:.2f}",
                'Kappa':       f"{kappa:.2f}",       # ✅ real kappa now
                'Sensitivity': f"{sensitivity:.2f}",
                'Specificity': f"{specificity:.2f}",
                'PPV':         f"{ppv:.2f}",
                'NPV':         f"{npv:.2f}",
                'AUC (95% CI)': auc_with_ci
            })

table3_df = pd.DataFrame(table3_rows)

