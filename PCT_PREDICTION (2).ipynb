    # Get predictions using locked threshold
    y_pred = (proba_test >= thr_locked).astype(int)

    # Calculate precision, recall, f1-score for each class
    precision, recall, f1, support = precision_recall_fscore_support(
        y_test, y_pred, labels=[0, 1], average=None, zero_division=0
    )

    # Macro average (unweighted mean)
    macro_avg = {
        'precision': np.mean(precision),
        'recall': np.mean(recall),
        'f1': np.mean(f1)
    }

    # Weighted average (by support)
    precision_w, recall_w, f1_w, _ = precision_recall_fscore_support(
        y_test, y_pred, average='weighted', zero_division=0
    )

    # Accuracy
    accuracy = accuracy_score(y_test, y_pred)

    # Store results
    table2_rows.append({
        'Model': model_name,
        'Metric': 'Precision',
        'Class 0': f"{precision[0]:.2f}",
        'Class 1': f"{precision[1]:.2f}",
        'Macro Average': f"{macro_avg['precision']:.2f}",
        'Weighted Average': f"{precision_w:.2f}",
        'Accuracy': f"{accuracy:.2f}"
    })

    table2_rows.append({
        'Model': model_name,
        'Metric': 'Recall',
        'Class 0': f"{recall[0]:.2f}",
        'Class 1': f"{recall[1]:.2f}",
        'Macro Average': f"{macro_avg['recall']:.2f}",
        'Weighted Average': f"{recall_w:.2f}",
        'Accuracy': ''
    })

    table2_rows.append({
        'Model': model_name,
        'Metric': 'F1-Score',
        'Class 0': f"{f1[0]:.2f}",
        'Class 1': f"{f1[1]:.2f}",
        'Macro Average': f"{macro_avg['f1']:.2f}",
        'Weighted Average': f"{f1_w:.2f}",
        'Accuracy': ''
    })

# Create DataFrame
table2_df = pd.DataFrame(table2_rows)

# Print for manuscript
print("\n" + table2_df.to_string(index=False))

# Save to Excel
table2_df.to_excel("Manuscript_Table2_Internal_Test_Performance.xlsx", index=False)
print("\n✅ Saved: Manuscript_Table2_Internal_Test_Performance.xlsx")


