# ============================================================
# ============================================================
# 15) External validation (all models) - DUAL THRESHOLDS
# ============================================================

# ============================================================
# EXTERNAL-ONLY THRESHOLDS (Balanced vs Sensitive)
# These thresholds are used ONLY for external validation reporting
# (Internal test still uses thr_locked chosen on CAL set)
# ============================================================
external_thresholds = {
    "RandomForest": {"balanced": 0.50, "sensitive": 0.25},
    "XGBoost": {"balanced": 0.40, "sensitive": 0.25},
    "SVM": {"balanced": 0.45, "sensitive": 0.25},
    "LogisticRegression": {"balanced": 0.45, "sensitive": 0.40},
}

print("\n" + "="*60)
print("EXTERNAL VALIDATION (DUAL THRESHOLDS: Balanced vs Sensitive)")
print("="*60)

X_ext = ext[base_features]

external_rows = []

for model_name, res in results.items():
    cal_model = res["calibrated"]

    proba_ext = cal_model.predict_proba(X_ext)[:, 1]

    # If external has labels, compute AUC/Brier once (threshold-independent)
    has_labels = (target_cont in ext.columns)
    if has_labels:
        y_ext_true = (ext[target_cont] >= 0.5).astype(int)
        auc_ext = roc_auc_score(y_ext_true, proba_ext)
        brier_ext = brier_score_loss(y_ext_true, proba_ext)
    else:
        y_ext_true = None
        auc_ext = np.nan
        brier_ext = np.nan

    # Get the two external-only thresholds for this model
    if model_name not in external_thresholds:
        print(f"⚠️ No external thresholds provided for {model_name}. Skipping dual-threshold eval.")
        continue

    thr_bal = external_thresholds[model_name]["balanced"]
    thr_sens = external_thresholds[model_name]["sensitive"]

    # Predictions for BOTH thresholds (external-only)
    pred_bal = (proba_ext >= thr_bal).astype(int)
    pred_sens = (proba_ext >= thr_sens).astype(int)

    # Save external file with both predictions
    ext_out = ext.copy()
    ext_out[f"{model_name}_Probability"] = proba_ext
    ext_out[f"{model_name}_Pred_Balanced_thr{thr_bal:.2f}"] = pred_bal
    ext_out[f"{model_name}_Pred_Sensitive_thr{thr_sens:.2f}"] = pred_sens
    ext_out.to_excel(f"External_{model_name}_DualThresholds.xlsx", index=False)

    # If labels exist, compute metrics for each threshold
    if has_labels:
        m_bal = metrics_at_threshold(y_ext_true, proba_ext, thr_bal)
        m_sens = metrics_at_threshold(y_ext_true, proba_ext, thr_sens)

        external_rows.append({
            "Model": model_name,
            "AUC": f"{auc_ext:.3f}",
            "Brier": f"{brier_ext:.3f}",
            "Strategy": "Balanced",
            "Threshold": f"{thr_bal:.2f}",
            "Sens": f"{m_bal['sens']:.3f}",
            "Spec": f"{m_bal['spec']:.3f}",
            "PPV": f"{m_bal['ppv']:.3f}",
            "NPV": f"{m_bal['npv']:.3f}",
            "Accuracy": f"{m_bal['acc']:.3f}",
        })

        external_rows.append({
            "Model": model_name,
            "AUC": f"{auc_ext:.3f}",
            "Brier": f"{brier_ext:.3f}",
            "Strategy": "Sensitive",
            "Threshold": f"{thr_sens:.2f}",
            "Sens": f"{m_sens['sens']:.3f}",
            "Spec": f"{m_sens['spec']:.3f}",
