# ============================================================
# 6) Helper functions for metrics
# ============================================================
def metrics_at_threshold(y_true, p, thr):
    y_pred = (p >= thr).astype(int)
    tn, fp, fn, tp = confusion_matrix(y_true, y_pred).ravel()
    sens = tp/(tp+fn) if (tp+fn) else np.nan
    spec = tn/(tn+fp) if (tn+fp) else np.nan
    ppv  = tp/(tp+fp) if (tp+fp) else np.nan
    npv  = tn/(tn+fn) if (tn+fn) else np.nan
    acc  = accuracy_score(y_true, y_pred)
    f1   = f1_score(y_true, y_pred)
    youden = sens + spec - 1
    balacc = (sens + spec)/2
    return {"thr":thr,"sens":sens,"spec":spec,"ppv":ppv,"npv":npv,"acc":acc,"f1":f1,"youden":youden,"balacc":balacc}

def bootstrap_auc_ci(y_true, prob, n_boot=2000, seed=42):
    rng = np.random.default_rng(seed)
    y_true = np.asarray(y_true)
    prob = np.asarray(prob)
    scores = []
    for _ in range(n_boot):
        idx = rng.integers(0, len(y_true), len(y_true))
        if len(np.unique(y_true[idx])) < 2:
            continue
        scores.append(roc_auc_score(y_true[idx], prob[idx]))
    scores = np.array(scores)
    return np.percentile(scores, [2.5, 50, 97.5])

def bootstrap_sens_spec_ci(y_true, prob, thr, n_boot=2000, seed=42):
    rng = np.random.default_rng(seed)
    y_true = np.asarray(y_true)
    prob = np.asarray(prob)
    sens_list, spec_list = [], []
    for _ in range(n_boot):
        idx = rng.integers(0, len(y_true), len(y_true))
        yt = y_true[idx]
        pt = prob[idx]
        if len(np.unique(yt)) < 2:
            continue
        pred = (pt >= thr).astype(int)
        tn, fp, fn, tp = confusion_matrix(yt, pred).ravel()
        sens = tp/(tp+fn) if (tp+fn) else np.nan
        spec = tn/(tn+fp) if (tn+fp) else np.nan
        sens_list.append(sens); spec_list.append(spec)
    return np.percentile(sens_list, [2.5, 50, 97.5]), np.percentile(spec_list, [2.5, 50, 97.5])


