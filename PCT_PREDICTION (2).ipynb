# ============================================================
# 1) Prespecified composite features (clinically motivated)
# ============================================================
class CompositeFeatureCreator(BaseEstimator, TransformerMixin):
    """
    Adds prespecified (clinically motivated) composite features.
    Implemented inside the pipeline so the same transformation is applied
    to train, test, and external data with no leakage.
    """
    def __init__(self, add_plcr=True):
        self.add_plcr = add_plcr
        self.feature_names_ = None

    def fit(self, X, y=None):
        X_df = X if isinstance(X, pd.DataFrame) else pd.DataFrame(X)
        self.feature_names_ = X_df.columns.tolist()
        return self

    def transform(self, X):
        X_df = X.copy() if isinstance(X, pd.DataFrame) else pd.DataFrame(X, columns=self.feature_names_)

        if "NE#" in X_df.columns and "CRP" in X_df.columns:
            X_df["NE#xCRP"] = X_df["NE#"] * X_df["CRP"]
        if "Creatinine" in X_df.columns and "CRP" in X_df.columns:
            X_df["ScrxCRP"] = X_df["Creatinine"] * X_df["CRP"]
        if self.add_plcr and ("P-LCR" in X_df.columns) and ("CRP" in X_df.columns):
            X_df["P-LCRxCRP"] = X_df["P-LCR"] * X_df["CRP"]

        return X_df

    def get_feature_names_out(self, input_features=None):
        out = self.feature_names_.copy() if self.feature_names_ else []
        for n in ["NE#xCRP", "ScrxCRP", "P-LCRxCRP"]:
            if n not in out:
                out.append(n)
        return np.array(out)


