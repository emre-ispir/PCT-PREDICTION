            "clf__min_samples_leaf": [1, 2, 4],
            "clf__max_features": ["sqrt", "log2"],
            "clf__bootstrap": [True, False],
            "clf__class_weight": [None, "balanced"]
        },
        "n_iter": 25
    },

    "XGBoost": {
        "pipeline": Pipeline([
            ("feature_creator", CompositeFeatureCreator(add_plcr=use_plcr)),
            ("imputer", SimpleImputer(strategy="median")),
            ("clf", XGBClassifier(random_state=42, eval_metric="logloss", n_jobs=-1, tree_method="hist"))
        ]),
        "param_dist": {
            "clf__n_estimators": [200, 400, 600, 800],
            "clf__max_depth": [3, 4, 5, 6, 8],
            "clf__learning_rate": [0.01, 0.05, 0.1, 0.2],
            "clf__subsample": [0.7, 0.8, 0.9, 1.0],
            "clf__colsample_bytree": [0.7, 0.8, 0.9, 1.0],
            "clf__min_child_weight": [1, 3, 5, 10],
            "clf__gamma": [0, 0.5, 1.0],
            "clf__reg_alpha": [0, 0.1, 0.5],
            "clf__reg_lambda": [1, 1.5, 2.0],
            "clf__scale_pos_weight": [1.0, scale_pos_weight]
        },
        "n_iter": 35
    },

    "SVM": {
        "pipeline": Pipeline([
            ("feature_creator", CompositeFeatureCreator(add_plcr=use_plcr)),
            ("imputer", SimpleImputer(strategy="median")),
            ("scaler", StandardScaler()),  # SVM needs scaling
            ("clf", SVC(random_state=42, probability=True))
        ]),
        "param_dist": {
            "clf__C": [0.01, 0.1, 1, 10, 100],
            "clf__gamma": ["scale", "auto", 0.001, 0.01, 0.1],
