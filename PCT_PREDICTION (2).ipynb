################Cost-Benefit Framework##################
import numpy as np
import pandas as pd
import matplotlib.pyplot as plt

class CostBenefitAnalysis:
    """
    Cost-benefit analysis for PCT testing strategy.
    """

    def __init__(self,
                 cost_pct_test=25,           # Cost of PCT test ($)
                 cost_unnecessary_abx=150,    # Cost of unnecessary antibiotics per day
                 cost_missed_case=5000,  # Cost of missed case (complications)
                 days_unnecessary_abx=3):     # Average days of unnecessary antibiotics

        self.cost_pct_test = cost_pct_test
        self.cost_unnecessary_abx = cost_unnecessary_abx
        self.cost_missed_case = cost_missed_case
        self.days_unnecessary_abx = days_unnecessary_abx

    def calculate_costs(self, y_true, y_pred, strategy_name="Model"):
        """
        Calculate total costs for a prediction strategy.

        Parameters:
        -----------
        y_true : array
            True PCT status (0=negative, 1=positive)
        y_pred : array
            Predicted PCT status (0=don't test, 1=test)

        Returns:
        --------
        costs : dict
            Breakdown of all costs
        """
        from sklearn.metrics import confusion_matrix

        tn, fp, fn, tp = confusion_matrix(y_true, y_pred).ravel()
        n = len(y_true)

        # Cost calculations

        # 1. PCT tests performed
        tests_performed = tp + fp  # Only test positive predictions
        cost_tests = tests_performed * self.cost_pct_test

        # 2. Missed cases (false negatives)
        # These patients should have gotten PCT test but didn't
        # May lead to delayed diagnosis and complications
        cost_missed = fn * self.cost_missed_case

        # 3. Unnecessary antibiotics (false positives)
        # Patients flagged as needing PCT who don't actually need it
        # May receive unnecessary antibiotics while waiting for PCT
        cost_unnecessary = fp * self.cost_unnecessary_abx * self.days_unnecessary_abx

        # Total cost
        total_cost = cost_tests + cost_missed + cost_unnecessary

        # Cost per patient
        cost_per_patient = total_cost / n

        return {
            'strategy': strategy_name,
            'n_patients': n,
            'pct_tests': tests_performed,
            'cost_pct_tests': cost_tests,
            'missed_cases': fn,
            'cost_missed_cases': cost_missed,
            'unnecessary_flags': fp,
            'cost_unnecessary_abx': cost_unnecessary,
            'total_cost': total_cost,
            'cost_per_patient': cost_per_patient,
            'tp': tp, 'tn': tn, 'fp': fp, 'fn': fn
        }

    def compare_strategies(self, y_true, strategies_dict):
        """
        Compare multiple testing strategies.

        Parameters:
        -----------
        y_true : array
            True PCT status
        strategies_dict : dict
            {'Strategy Name': predicted_labels}

        Returns:
        --------
        comparison_df : DataFrame
            Cost comparison across strategies
        """
        results = []

        for strategy_name, y_pred in strategies_dict.items():
            costs = self.calculate_costs(y_true, y_pred, strategy_name)
            results.append(costs)

        return pd.DataFrame(results)

    def plot_cost_comparison(self, comparison_df, save_path=None):
        """
        Visualize cost comparison.
        """
        fig, axes = plt.subplots(2, 2, figsize=(14, 10))

        strategies = comparison_df['strategy']

        # 1. Total cost comparison
        axes[0, 0].bar(strategies, comparison_df['total_cost'], color='steelblue')
        axes[0, 0].set_ylabel('Total Cost ($)', fontsize=11)
        axes[0, 0].set_title('Total Cost by Strategy', fontsize=12, fontweight='bold')
        axes[0, 0].tick_params(axis='x', rotation=45)
        axes[0, 0].grid(axis='y', alpha=0.3)

        # 2. Cost per patient
        axes[0, 1].bar(strategies, comparison_df['cost_per_patient'], color='coral')
        axes[0, 1].set_ylabel('Cost per Patient ($)', fontsize=11)
        axes[0, 1].set_title('Cost per Patient by Strategy', fontsize=12, fontweight='bold')
        axes[0, 1].tick_params(axis='x', rotation=45)
        axes[0, 1].grid(axis='y', alpha=0.3)

        # 3. Cost breakdown (stacked bar)
        cost_components = comparison_df[['cost_pct_tests', 'cost_missed_cases',
                                         'cost_unnecessary_abx']].values.T

        x = np.arange(len(strategies))
        width = 0.6

        axes[1, 0].bar(x, cost_components[0], width, label='PCT Tests', color='lightblue')
        axes[1, 0].bar(x, cost_components[1], width, bottom=cost_components[0],
                      label='Missed cases', color='salmon')
        axes[1, 0].bar(x, cost_components[2], width,
                      bottom=cost_components[0] + cost_components[1],
                      label='Unnecessary Treatment', color='lightgreen')

        axes[1, 0].set_ylabel('Cost ($)', fontsize=11)
        axes[1, 0].set_title('Cost Component Breakdown', fontsize=12, fontweight='bold')
        axes[1, 0].set_xticks(x)
        axes[1, 0].set_xticklabels(strategies, rotation=45)
        axes[1, 0].legend()
        axes[1, 0].grid(axis='y', alpha=0.3)

        # 4. Number of PCT tests
        axes[1, 1].bar(strategies, comparison_df['pct_tests'], color='mediumseagreen')
        axes[1, 1].set_ylabel('Number of PCT Tests', fontsize=11)
        axes[1, 1].set_title('PCT Tests Performed by Strategy', fontsize=12, fontweight='bold')
        axes[1, 1].tick_params(axis='x', rotation=45)
        axes[1, 1].grid(axis='y', alpha=0.3)

        plt.tight_layout()

        if save_path:
            plt.savefig(save_path, dpi=300, bbox_inches='tight')

        plt.show()


