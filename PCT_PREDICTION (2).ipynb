}


# ============================================================
# 8) Train all models with GroupKFold CV
# ============================================================
cv = GroupKFold(n_splits=5)
results = {}

print("\n" + "="*60)
print("TRAINING ALL MODELS")
print("="*60)

for model_name, config in models.items():
    print(f"\n{'='*60}")
    print(f"Training: {model_name}")
    print(f"{'='*60}")

    rs = RandomizedSearchCV(
        estimator=config["pipeline"],
        param_distributions=config["param_dist"],
        n_iter=config["n_iter"],
        scoring="roc_auc",
        cv=cv,
        random_state=42,
        n_jobs=-1,
        verbose=0
    )

    rs.fit(X_train, y_train, groups=groups_train)
    best_pipe = rs.best_estimator_

    print(f"✅ Best params: {rs.best_params_}")
    print(f"   Best CV AUC: {rs.best_score_:.3f}")

    # Calibrate on CAL set
    cal = CalibratedClassifierCV(best_pipe, method="isotonic", cv="prefit")
    cal.fit(X_cal, y_cal)

    # Predictions
    proba_cal = cal.predict_proba(X_cal)[:, 1]
    proba_test = cal.predict_proba(X_test)[:, 1]

    # Metrics on test
    auc_test = roc_auc_score(y_test, proba_test)
    brier_test = brier_score_loss(y_test, proba_test)

    # Threshold selection on CAL set
    thresholds = np.round(np.linspace(0.05, 0.95, 19), 2)
    thr_table_cal = pd.DataFrame([metrics_at_threshold(y_cal, proba_cal, t) for t in thresholds])
    thr_locked = thr_table_cal.sort_values("balacc", ascending=False).iloc[0]["thr"]

    # Bootstrap CIs on TEST
    auc_ci = bootstrap_auc_ci(y_test, proba_test, n_boot=2000)
    sens_ci, spec_ci = bootstrap_sens_spec_ci(y_test, proba_test, thr_locked, n_boot=2000)

    # Test metrics at locked threshold
    test_metrics = metrics_at_threshold(y_test, proba_test, thr_locked)

    print(f"\n   Internal TEST: AUC={auc_test:.3f}, Brier={brier_test:.3f}")
    print(f"   Locked threshold: {thr_locked}")
    print(f"   Sens={test_metrics['sens']:.3f}, Spec={test_metrics['spec']:.3f}")
    print(f"   PPV={test_metrics['ppv']:.3f}, NPV={test_metrics['npv']:.3f}")

    # Store results
    results[model_name] = {
        "best_pipe": best_pipe,
        "calibrated": cal,
        "proba_test": proba_test,
        "proba_cal": proba_cal,
        "auc_test": auc_test,
        "brier_test": brier_test,
        "thr_locked": thr_locked,
        "thr_table_cal": thr_table_cal,
        "test_metrics": test_metrics,
        "auc_ci": auc_ci,
        "sens_ci": sens_ci,
        "spec_ci": spec_ci,
        "best_params": rs.best_params_
    }


